# MongoDB Atlas Connection String
# Replace with your actual MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/stemquest?retryWrites=true&w=majority

# Secret key for JWT signature
# You can generate a random one using: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_change_me_in_production

# Frontend URL for CORS (in production)
FRONTEND_URL=https://your-stemquest-app.vercel.app
